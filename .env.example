# ═══════════════════════════════════════════════════════════════
# Agraound / AETHERYON Systems — Backend
# Copiá como .env y completá los valores reales.
# NUNCA subas .env a git.
# ═══════════════════════════════════════════════════════════════

# ── MongoDB Atlas ────────────────────────────────────────────────
# 1. En Atlas: Connect → Drivers → Python → copiá la SRV string
# 2. Reemplazá <db_password> con la contraseña de gntprsnl_db_user
# 3. El appName=Cluster0 ya viene en la string — dejarlo
MONGODB_URI=mongodb+srv://gntprsnl_db_user:<db_password>@cluster0.0qrrq1w.mongodb.net/?appName=Cluster0
MONGODB_DB=agraound

# ── Resend ───────────────────────────────────────────────────────
# Obtené tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=nda@tudominio.com
EMAIL_FROM_NAME=Agraound Consulting
EMAIL_PROVIDER_TO=admin@agraound.site  # debe ser un email completo, no solo el dominio

# ── App ──────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
MAX_UPLOAD_MB=10
UPLOAD_DIR=uploads

# ── Cloudflare R2 ────────────────────────────────────────────────
# Pasos para obtener las credenciales (ver R2_SETUP.md):
# 1. Cloudflare Dashboard → R2 → Manage R2 API Tokens
# 2. Create API Token
#    - Permissions: Cloudflare R2 → Edit   ← IMPORTANTE: seleccionar este
#    - Account Resources: Include → All accounts (o solo tu cuenta)
#    - TTL: sin fecha de expiración recomendado para producción
# 3. Copiá Access Key ID y Secret Access Key (solo se muestran una vez)
#
# Account ID lo encontrás en: Cloudflare Dashboard → barra lateral derecha
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<access_key_id>
R2_SECRET_ACCESS_KEY=<secret_access_key>
R2_BUCKET_NAME=agraound-docs
R2_PRESIGNED_EXPIRY=3600
